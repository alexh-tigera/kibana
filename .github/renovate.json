{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "baseBranchPatterns": ["8.19"],
  "enabledManagers": ["npm", "github-actions"],
  "ignorePaths": ["**/__fixtures__/**", "**/fixtures/**"],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "rangeStrategy": "bump",
  "semanticCommits": "disabled",
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "enabled": false
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "vulnerability", "renovate"]
  },
  "osvVulnerabilityAlerts": true,
  "lockFileMaintenance": {
    "enabled": false
  }
}
